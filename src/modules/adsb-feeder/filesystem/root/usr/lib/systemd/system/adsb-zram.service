[Unit]
Description=ADS-B Feeder Zram Service
# TODO this was only ever enabled for full image installs. do we want this?+++++++++
[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/adsb
ExecStart=/bin/bash /opt/adsb/scripts/zram-swap.sh
TimeoutStartSec=0
SyslogIdentifier=adsb-zram

[Install]
WantedBy=default.target
